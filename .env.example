# ── Emby 媒体服务器 ──────────────────────────────────
EMBY_URL=http://192.168.1.100:8096
EMBY_API_KEY=your_emby_api_key_here

# ── 代理（访问 Gemini / OpenRouter 等国际 API 时使用）──
# 留空则不使用代理
PROXY_HOST=http://127.0.0.1:7890

# ── Docker 路径映射（可选）──────────────────────────────
# Emby 运行在 Docker 时，将容器内路径映射到宿主机实际路径
# 格式：容器路径:宿主机路径，多条用分号分隔
# 示例：DOCKER_PATH_MAP=/video:/volume1/video/link
DOCKER_PATH_MAP=

# ── AI 服务商 API Keys ────────────────────────────────
# 填写至少一个，其余留空即可

# 硅基流动 https://siliconflow.cn
SILICONFLOW_KEY=

# 阿里云百炼 https://bailian.aliyun.com
ALIYUN_KEY=

# 月之暗面 (Kimi) https://platform.moonshot.cn
MOONSHOT_KEY=

# 智谱 BigModel https://open.bigmodel.cn
ZHIPU_KEY=

# Google Gemini https://aistudio.google.com/apikey
GEMINI_KEY=

# OpenRouter https://openrouter.ai/keys
OPENROUTER_KEY=
